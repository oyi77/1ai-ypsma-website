---
import DoaModal from '../components/islands/DoaModal';
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'YPSM Jombang — Yayasan Pendidikan & Sosial Ma\'arif',
  description = 'Yayasan Pendidikan dan Sosial Ma\'arif (YPSM) Jombang — mengelola RA Perwanida, MI Miftahul Ulum, SMP Plus Ma\'arif, dan PPTQ. Berdiri sejak 1968, mencetak 3.000+ alumni berprestasi.',
  canonical,
  ogImage = '/images/campaigns/Berdoa.webp',
} = Astro.props;

const pageUrl = new URL(Astro.url.pathname, 'https://ypsma.org').href;
const canonicalUrl = canonical || pageUrl;
const midtransClientKey = import.meta.env.PUBLIC_MIDTRANS_CLIENT_KEY || 'Mid-client-xxx';
---

<!doctype html>
<html lang="id" data-lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0D3F3C" />
    <link rel="icon" type="image/webp" href="/logo-ypsma.webp" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={`https://ypsma.org${ogImage}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preload" href="/images/campaigns/IMG_1860.webp" as="image" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Amiri:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="prefetch" href="/program/" />
    <link rel="prefetch" href="/tentang-kami/" />
    <link rel="prefetch" href="/transparansi/" />

    <title>{title}</title>

    <!-- Structured Data -->
