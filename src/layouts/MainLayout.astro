---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'YPSM Jombang — Yayasan Pendidikan & Sosial Ma\'arif',
  description = 'Yayasan Pendidikan dan Sosial Ma\'arif (YPSM) Jombang — mengelola RA Perwanida, MI Miftahul Ulum, SMP Plus Ma\'arif, dan PPTQ. Berdiri sejak 1968, mencetak 3.000+ alumni berprestasi.'
} = Astro.props;

// Midtrans client key — loaded via cf env or fallback
const midtransClientKey = import.meta.env.PUBLIC_MIDTRANS_CLIENT_KEY || 'Mid-client-xxx';
---

