  </head>
  <body class="font-body antialiased">
    <slot />
    <DoaModal client:load />
    <!-- Donate link interceptor -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href^="/donasi"]');
        if (link) {
          e.preventDefault();
          var url = new URL(link.href, window.location.origin);
          var tipe = url.searchParams.get('tipe') || 'general';
          var label = (link.getAttribute('data-campaign-label') || link.textContent || 'Donasi').trim();
          window.dispatchEvent(new CustomEvent('campaign:donate', { detail: { campaign: tipe, campaignLabel: label } }));
        }
      });
    </script>

    <!-- Language switcher script -->
    <script is:inline>
      (function() {
        var LS_KEY = 'ypsma-lang';
        function getLang() {
          var m = document.cookie.match(new RegExp('(?:^|; )' + LS_KEY + '=([^;]*)'));
          return (m && m[1] === 'en') ? 'en' : 'id';
        }
        function setLangCookie(l) { document.cookie = LS_KEY + '=' + l + ';path=/;max-age=31536000;SameSite=Lax'; }
        function applyLang(lang) {
          document.documentElement.lang = lang;
          // Translate all data-i18n elements
          var keys = window.__TRANSLATIONS || {};
          document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var key = el.getAttribute('data-i18n');
            if (keys[lang] && keys[lang][key]) {
              el.textContent = keys[lang][key];
            }
          });
          // Translate all data-i18n-placeholder elements
          document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
            var key = el.getAttribute('data-i18n-placeholder');
            if (keys[lang] && keys[lang][key]) {
              el.placeholder = keys[lang][key];
            }
          });
          // Hide/show lang-specific spans
          document.querySelectorAll('[data-lang-vis]').forEach(function(el) {
            el.hidden = el.getAttribute('data-lang-vis') !== lang;
          });
        }
        // Load translations & apply
        var lang = getLang();
        setLangCookie(lang);
        applyLang(lang);
      })();
    </script>
  </body>
</html>

<style is:global>
