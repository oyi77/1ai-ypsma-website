---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'YPSM Jombang — Yayasan Pendidikan & Sosial Ma\'arif',
  description = 'Yayasan Pendidikan dan Sosial Ma\'arif (YPSM) Jombang — mengelola RA Perwanida, MI Miftahul Ulum, SMP Plus Ma\'arif, dan PPTQ. Berdiri sejak 1968, mencetak 3.000+ alumni berprestasi.'
} = Astro.props;

// Midtrans client key — loaded via cf env or fallback
const midtransClientKey = import.meta.env.PUBLIC_MIDTRANS_CLIENT_KEY || 'Mid-client-xxx';
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0D3F3C" />
    <link rel="icon" type="image/png" href="/images/logoypma.png" />
    <link rel="canonical" href="https://ypsma.org/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://ypsma.org/" />
    <meta property="og:image" content="https://ypsma.org/images/campaigns/Berdoa.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Amiri:wght@400;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        { "@type": "Organization", "name": "Yayasan Pendidikan & Sosial Ma'arif Jombang", "alternateName": "YPSM", "url": "https://ypsma.org", "logo": "https://ypsma.org/favicon.svg", "description": "Yayasan pendidikan Islam berkualitas yang mengelola 4 unit pendidikan di Jombang sejak 1968", "foundingDate": "1968", "address": { "@type": "PostalAddress", "streetAddress": "Ds. Gondek, Mojowarno", "addressLocality": "Mojowarno", "addressRegion": "Jawa Timur", "postalCode": "61475", "addressCountry": "ID" }, "email": "pptqdarussalamgondek@gmail.com", "telephone": "+6282234551160" },
        { "@type": "EducationalOrganization", "name": "MI Miftahul Ulum", "description": "Madrasah Ibtidaiyah swasta di Gondek, Mojowarno", "foundingDate": "1968" },
        { "@type": "EducationalOrganization", "name": "RA Perwanida", "description": "PAUD/TK Islam di Gondek, Mojowarno", "foundingDate": "1980" },
        { "@type": "EducationalOrganization", "name": "PPTQ Darussalam", "description": "Pondok Pesantren Tahfidzhul Qur'an di Ngelo, Gondek", "foundingDate": "2015" },
        { "@type": "EducationalOrganization", "name": "SMP Plus Ma'arif", "description": "SMP swasta di bawah naungan YPSM Jombang", "foundingDate": "1988" }
      ]
    })} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7723KTXZBG"></script>
    <script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','G-7723KTXZBG');`} />

    <!-- Meta Pixel -->
    <script set:html={`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','771021905629860');fbq('track','PageView');`} />
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=771021905629860&ev=PageView&noscript=1" /></noscript>
  </head>
  <body class="font-body antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0D3F3C" />
    <link rel="icon" type="image/png" href="/images/logoypma.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&family=Amiri:wght@400;700&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body class="font-body antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
