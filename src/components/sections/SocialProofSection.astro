---
// Social Proof — live activity & progress
---

<section class="bg-white py-12">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Live activity ticker -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-6">
      <div class="flex items-center gap-2 text-sm text-neutral-500">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        <span><strong class="text-neutral-800">17</strong> orang berdonasi hari ini</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-neutral-500">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        <span><strong class="text-neutral-800">3</strong> menit lalu — seseorang dari Surabaya berdonasi Rp 150.000</span>
      </div>
    </div>

    <!-- Monthly target progress -->
    <div class="max-w-2xl mx-auto">
      <div class="flex justify-between text-sm mb-2">
        <span class="text-neutral-600 font-semibold">Target Bulanan</span>
        <div class="text-right">
          <span class="text-coral-600 font-bold">Rp 85 Juta</span>
          <span class="text-neutral-400"> / Rp 150 Juta</span>
        </div>
      </div>
      <div class="w-full bg-neutral-100 rounded-full h-3 overflow-hidden">
        <div class="h-3 rounded-full bg-gradient-to-r from-coral-500 to-secondary-500" style="width: 57%"></div>
      </div>
      <div class="flex justify-between text-xs text-neutral-400 mt-2">
        <span>🎯 57% terkumpul</span>
        <span>⏳ 12 hari lagi</span>
      </div>
    </div>
  </div>
</section>
