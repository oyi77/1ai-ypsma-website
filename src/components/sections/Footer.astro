---
import {
  SITE_NAME,
  ORG_NAME,
  NAV_ITEMS,
  CONTACT_INFO,
  SITE_LOGO,
} from '../../lib/constants';
---

<footer class="bg-primary-900 text-white/80">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Column 1: Logo & About -->
      <div>
        <img
          src={SITE_LOGO}
          alt={SITE_NAME}
          class="h-14 mb-4 brightness-0 invert"
          loading="lazy"
        />
        <h3 class="text-white font-bold text-lg mb-2" data-i18n="footer.siteName">{SITE_NAME}</h3>
        <p class="text-sm leading-relaxed text-white/60" data-i18n="footer.tagline">
          {ORG_NAME} &mdash; mencetak generasi beriman, berilmu, dan berakhlak mulia sejak 1968.
        </p>

        <!-- Social media icons -->
        <div class="flex items-center gap-3 mt-5">
          <a
            href={CONTACT_INFO.social.facebook}
            class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-secondary-500/20 transition-colors"
            aria-label="Facebook"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-4 h-4 text-white/70" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>

          <a
            href={CONTACT_INFO.social.instagram}
            class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-secondary-500/20 transition-colors"
            aria-label="Instagram"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-4 h-4 text-white/70" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>

          <a
            href={CONTACT_INFO.social.youtube}
            class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-secondary-500/20 transition-colors"
            aria-label="YouTube"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-4 h-4 text-white/70" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>

          <a
            href={CONTACT_INFO.social.tiktok}
            class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-secondary-500/20 transition-colors"
            aria-label="TikTok"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-4 h-4 text-white/70" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Navigasi -->
      <div>
        <h4 class="text-white font-bold text-lg mb-5" data-i18n="footer.navigation">Navigasi</h4>
        <ul class="space-y-3">
          {
            NAV_ITEMS.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-white/60 hover:text-secondary-400 transition-colors text-sm"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Column 3: Program -->
      <div>
        <h4 class="text-white font-bold text-lg mb-5" data-i18n="footer.programs">Program</h4>
        <ul class="space-y-3">
          <li>
            <a href="/program/ra-perwanida/" class="text-white/60 hover:text-secondary-400 transition-colors text-sm" data-i18n="footer.program.raPerwanida">
              RA Perwanida
            </a>
          </li>
          <li>
            <a href="/program/mi-miftahul-ulum/" class="text-white/60 hover:text-secondary-400 transition-colors text-sm" data-i18n="footer.program.miMiftahulUlum">
              MI Miftahul Ulum
            </a>
          </li>
          <li>
            <a href="/program/smp-plus/" class="text-white/60 hover:text-secondary-400 transition-colors text-sm" data-i18n="footer.program.smpPlus">
              SMP Plus Ma'arif
            </a>
          </li>
          <li>
            <a href="/program/pptq/" class="text-white/60 hover:text-secondary-400 transition-colors text-sm" data-i18n="footer.program.pptq">
              PPTQ
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Kontak -->
      <div>
        <h4 class="text-white font-bold text-lg mb-5" data-i18n="footer.contact">Kontak</h4>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-secondary-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-white/60">{CONTACT_INFO.address}</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-secondary-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href={`tel:${CONTACT_INFO.phone}`} class="text-white/60 hover:text-secondary-400 transition-colors">
              {CONTACT_INFO.phone}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-secondary-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href={`mailto:${CONTACT_INFO.email}`} class="text-white/60 hover:text-secondary-400 transition-colors">
              {CONTACT_INFO.email}
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-white/40">
      <p data-i18n="footer.copyright">&copy; 2026 {SITE_NAME} Jombang. All rights reserved.</p>

      <div class="flex items-center gap-3">
        <a href="/kebijakan-privasi/" class="hover:text-secondary-400 transition-colors" data-i18n="footer.privacyPolicy">Kebijakan Privasi</a>
        <span class="text-white/20">|</span>
        <a href="/syarat-ketentuan/" class="hover:text-secondary-400 transition-colors" data-i18n="footer.terms">Syarat &amp; Ketentuan</a>
      </div>

      <p class="text-xs" data-i18n="footer.builtWithLove">Dibangun dengan cinta untuk para donatur</p>
    </div>
  </div>
</footer>
