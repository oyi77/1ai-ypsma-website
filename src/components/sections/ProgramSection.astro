---
import { CAMPAIGNS } from '../../data/campaigns';
---

<section id="program" class="bg-primary-900 text-white py-20">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Heading -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white" data-i18n="programs.title">
        Program Donasi
      </h2>
      <p class="text-white/70 mt-4 max-w-2xl mx-auto" data-i18n="programs.subtitle">
        Pilih program donasi yang paling sesuai dengan hatimu
      </p>
    </div>

    <!-- Campaign Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        CAMPAIGNS.map((campaign) => (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:border-secondary-500/50 transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <h3 class="text-xl font-bold text-white">{campaign.title}</h3>
              <span class="text-xs bg-coral-500/20 text-coral-300 px-2 py-1 rounded-full whitespace-nowrap">{campaign.badge}</span>
            </div>
            <p class="text-white/70 text-sm mb-4">{campaign.subtitle}</p>
            <div class="flex flex-wrap gap-4 mb-4">
              {campaign.stats.slice(0,3).map(s => (
                <div>
                  <span class="text-secondary-400 font-bold">{s.value}</span>
                  <span class="text-white/50 text-sm ml-1">{s.label}</span>
                </div>
              ))}
            </div>
            <div class="border-t border-white/10 pt-3 flex items-center justify-between">
              <span class="text-white/50 text-sm">Budget: {campaign.budgetTotal}/bulan</span>
              <a href={"/lp-" + campaign.slug + ".html"} class="inline-block bg-coral-500 hover:bg-coral-600 text-white px-4 py-2 rounded-lg font-semibold text-sm transition-all duration-200" data-campaign-label={campaign.title}>
                Donasi
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
