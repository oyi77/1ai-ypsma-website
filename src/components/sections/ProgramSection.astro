---
import { ORG_SHORT } from '../../lib/constants';
import { programs, donationTiers } from '../../data/programs';
---

<section id="program" class="bg-neutral-50 py-20">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Heading -->
    <div class="text-center mb-12">
      <h2 class="section-heading section-heading-center text-3xl md:text-4xl text-primary-900 inline-block" data-i18n="programs.title">
        Program Pendidikan Kami
      </h2>
      <p class="text-neutral-600 mt-4 max-w-2xl mx-auto" data-i18n="programs.subtitle">
        Empat lembaga pendidikan di bawah naungan YPSM
      </p>
    </div>

    <!-- Program Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      {
        programs.map((program) => (
          <div class="bg-white rounded-xl p-6 shadow-soft card-hover flex flex-col">
            <!-- Icon Placeholder -->
            <div class="w-14 h-14 rounded-full bg-primary-900/10 flex items-center justify-center mb-4">
              <span class="text-xl font-bold text-primary-900 font-heading">
                {program.title.charAt(0)}
              </span>
            </div>

            <!-- Title -->
            <h3 class="font-heading text-xl font-bold text-primary-900 mb-2">
              {program.title}
            </h3>

            <!-- Description -->
            <p class="text-neutral-600 text-sm mb-4 flex-1">
              {program.description}
            </p>

            <!-- Stats Row -->
            <div class="flex gap-3 mb-4">
              {
                program.stats?.slice(0, 2).map((stat) => (
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-primary-700 bg-primary-50 rounded-full px-3 py-1">
                    <span class="font-bold">{stat.value}</span>
                    {stat.label}
                  </span>
                ))
              }
            </div>

            <!-- CTA Link -->
            <a
              href={`/program/${program.slug}/`}
              class="text-coral-500 font-semibold text-sm hover:underline inline-flex items-center gap-1 mt-auto"
            >
              Bantu Program Ini
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))
      }
    </div>

    <!-- Donation Tiers Section -->
    <div class="text-center mb-10">
      <h3 class="section-heading section-heading-center text-2xl md:text-3xl text-primary-900 inline-block">
        Pilih Cara Donasi
      </h3>
      <p class="text-neutral-600 mt-4 max-w-xl mx-auto">
        Setiap donasi Anda adalah investasi untuk masa depan generasi penerus umat
      </p>
    </div>

    <!-- Donation Tier Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
      {
        donationTiers.map((tier, i) => {
          const isMiddle = i === 1;
          return (
            <div
              class={`bg-white rounded-xl p-6 shadow-soft card-hover flex flex-col ${
                isMiddle ? 'md:scale-[1.02] border-2 border-secondary-500/20' : ''
              }`}
            >
              <!-- Icon -->
              <div class="w-12 h-12 rounded-full bg-secondary-500/10 flex items-center justify-center mb-4">
                <span class="text-lg font-bold text-secondary-700 font-heading">
                  {tier.title.charAt(0)}
                </span>
              </div>

              <!-- Title & Subtitle Badge -->
              <div class="flex items-start justify-between gap-2 mb-3">
                <h3 class="font-heading text-lg font-bold text-primary-900">
                  {tier.title}
                </h3>
                <span class="shrink-0 text-xs font-semibold px-3 py-1 rounded-full bg-secondary-100 text-secondary-700">
                  {tier.subtitle}
                </span>
              </div>

              <p class="text-neutral-600 text-sm mb-4">
                {tier.description}
              </p>

              <!-- Features -->
              <ul class="space-y-2 mb-6 flex-1">
                {
                  tier.features.map((feature) => (
                    <li class="flex items-start gap-2 text-sm text-neutral-600">
                      <svg class="w-4 h-4 text-secondary-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                      {feature}
                    </li>
                  ))
                }
              </ul>

              <!-- Price -->
              <div class="text-2xl font-bold text-primary-900 mb-4">
                {tier.amount}
              </div>

              <!-- CTA -->
              <a
                href={`/donasi/?tipe=${tier.id}`}
                class="inline-block text-center bg-coral-500 text-white rounded-lg px-6 py-3 font-semibold hover:bg-coral-600 transition-colors"
              >
                {tier.cta}
              </a>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
