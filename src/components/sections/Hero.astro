---
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Image -->
  <img
    src="/images/drive-new/wisuda/wisuda-2.webp"
    alt="Santri wisuda hafidz Al-Qur'an"
    width="1920"
    height="1080"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-primary-900/85 via-primary-900/70 to-primary-900/60"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 py-20 text-center">
    <!-- Gold divider -->
    <div class="h-1 w-20 bg-secondary-500 mx-auto rounded mb-4"></div>

    <!-- Urgency pill — simplified, 2 numbers only -->
    <div class="inline-block bg-coral-500/20 text-coral-300 text-xs md:text-sm px-3 md:px-4 py-1.5 rounded-full mb-4 md:mb-6 font-medium">
      🚨 Sisa 12 Hari — Target Bulanan: Rp 150 Juta
    </div>

    <!-- Headline — shorter on mobile, full on desktop -->
    <h1 class="text-2xl md:text-5xl font-bold text-white font-heading leading-tight mb-3 md:mb-4">
      <span class="md:hidden">Jam 03.30, Ahmad sudah bangun menghafal Al-Qur'an.</span>
      <span class="hidden md:inline">Jam 03.30, Ahmad sudah bangun menghafal Al-Qur'an.<br />
      <span class="text-secondary-400">Tapi sebagian masih belajar</span> di kamar dengan lampu redup.</span>
    </h1>

    <!-- Subtitle — focused on the key numbers only -->
    <p class="text-sm md:text-lg text-white/80 max-w-3xl mx-auto mb-3 md:mb-4 leading-relaxed">
      Ahmad adalah satu dari <strong class="text-white">249 santri penghafal Qur'an</strong> yang
      berjuang dalam keterbatasan. Mereka menanti uluran tangan kita.
    </p>

    <!-- Impact line — single actionable number -->
    <p class="text-xs md:text-base text-white/60 max-w-2xl mx-auto mb-6 md:mb-8 italic">
      "Cukup <strong class="text-secondary-400">Rp 50.000/hari</strong> = satu santri hafidz bisa terus belajar, makan, & tinggal di pondok."
    </p>
    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <button
        onclick="event.preventDefault();window.dispatchEvent(new CustomEvent('campaign:donate',{detail:{campaign:'general',campaignLabel:'Bantu Santri Hafidz'}}));if(window.fbq)fbq('track','Donate',{content_name:'Bantu Santri Hafidz',content_category:'Hero'});"
        class="bg-coral-500 hover:bg-coral-600 text-white px-10 py-4 rounded-lg font-bold text-lg transition-all duration-200 shadow-soft hover:shadow-medium"
      >
        ❤️ Bantu Ahmad & 249 Santri Hafidz
      </button>
      <a
        href="#program"
        class="border-2 border-white/30 text-white hover:bg-white/10 px-10 py-4 rounded-lg font-semibold transition-all duration-200"
      >
        Lihat Semua Program
      </a>
    </div>
  </div>
</section>
