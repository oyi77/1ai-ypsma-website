---
// Ayobantu campaigns data
const AYO_BANTU_CAMPAIGNS = [
  {
    title: 'Sedekah Pangan Santri Penghafal Qur\'an',
    url: 'https://www.ayobantu.com/campaign/sedekah-pangan-santri-maari',
    donateUrl: 'https://www.ayobantu.com/campaign/sedekah-pangan-santri-maari/donate',
    icon: '🍚',
  },
  {
    title: 'Sedekah Al-Qur\'an untuk Santri Penghafal',
    url: 'https://www.ayobantu.com/campaign/sedekah-quran-santri-maarif',
    donateUrl: 'https://www.ayobantu.com/campaign/sedekah-quran-santri-maarif/donate',
    icon: '📖',
  },
  {
    title: 'Patungan Listrik untuk Asrama Santri',
    url: 'https://www.ayobantu.com/campaign/patungan-listrik-santri-maarif',
    donateUrl: 'https://www.ayobantu.com/campaign/patungan-listrik-santri-maarif/donate',
    icon: '💡',
  },
];
---

<section class="bg-primary-900 text-white py-20">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Heading -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Galang Dana via AyoBantu
      </h2>
      <p class="text-white/70 mt-3 max-w-2xl mx-auto">
        Dukung program-program YPSMA melalui platform donasi online AyoBantu
      </p>
    </div>

    <!-- Campaign Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      {
        AYO_BANTU_CAMPAIGNS.map((campaign) => (
          <a
            href={campaign.url}
            target="_blank"
            rel="noopener noreferrer"
            class="block bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:border-secondary-500/50 transition-all duration-300 group"
          >
            <div class="text-4xl mb-4">{campaign.icon}</div>
            <h3 class="text-lg font-semibold text-white mb-4 group-hover:text-secondary-300 transition-colors">
              {campaign.title}
            </h3>
            <span class="inline-flex items-center gap-2 text-sm text-secondary-400 font-medium">
              Donasi Sekarang
              <svg stroke="currentColor" fill="none" viewBox="0 0 24 24" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>

    <!-- View all link -->
    <div class="text-center">
      <a
        href="https://www.ayobantu.com/campaign?campaigner=YAYASAN%20PENDIDIKAN%20DAN%20SOSIAL%20MAARIF"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-white/60 hover:text-secondary-400 transition-colors text-sm"
      >
        Lihat semua campaign di AyoBantu
        <svg stroke="currentColor" fill="none" viewBox="0 0 24 24" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
