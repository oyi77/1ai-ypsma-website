---

<section id="kondisi" class="bg-primary-900 text-white py-20">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Heading -->
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold font-title mb-4">
        Kondisi Santri Kita
      </h2>
      <p class="text-white/70 max-w-2xl mx-auto">
        Inilah kondisi nyata yang kami hadapi setiap hari. Program donasi kami lahir dari kebutuhan
        ini — bukan dari meja rapat, tapi dari lapangan.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        kondisi.map((item) => (
          <a
            href={`/program/${item.slug}`}
            class="group block bg-white/5 hover:bg-white/10 rounded-xl overflow-hidden border border-white/10 hover:border-coral-500/50 transition-all duration-300"
          >
            <!-- Image -->
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={item.photo}
                alt={item.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>

            <!-- Content -->
            <div class="p-5 flex flex-col gap-3">
              <!-- Title -->
              <div class="flex items-start gap-3">
                <span class="text-xl shrink-0 mt-0.5">{item.icon}</span>
                <h3 class="font-bold text-base leading-snug">{item.title}</h3>
              </div>

              <!-- Subtitle -->
              <p class="text-white/50 text-sm -mt-1">{item.subtitle}</p>

              <!-- Stats -->
              <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm">
                {
                  item.stats.map((s) => (
                    <span class="text-white/80">
                      <strong class="text-coral-400 font-bold">{s.value}</strong>
                      <span class="text-white/50"> {s.label}</span>
                    </span>
                  ))
                }
              </div>

              <!-- Program Label -->
              <span class="text-xs text-white/40 uppercase tracking-wider">
                {item.programLabel}
              </span>

              <!-- Target -->
              <div class="flex items-center justify-between mt-1">
                <span class="text-sm text-white/60">Target</span>
                <span class="text-lg font-bold text-coral-400">{item.target}</span>
              </div>

              <!-- CTA -->
              <span class="inline-flex items-center justify-center gap-2 bg-coral-500 hover:bg-coral-600 text-white font-semibold text-sm rounded-lg px-4 py-2.5 transition-all group-hover:gap-3 mt-1">
                {item.cta}
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-10">
      <a
        href="/tentang-kami#kondisi"
        class="inline-flex items-center gap-2 text-white/60 hover:text-white transition-colors text-sm"
      >
        Lihat Semua Program Donasi
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </div>
</section>
