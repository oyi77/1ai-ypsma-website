---
// Kondisi Santri — jembatan emosional antara Hero dan Program
interface KondisiItem {
  icon: string;
  title: string;
  body: string;
  photo: string;
  alt: string;
}

const kondisi: KondisiItem[] = [
  {
    icon: '\uD83C\uDF5A',
    title: 'Lapar Mengancam Hafalan Mereka',
    body: 'Setiap hari 250 santri harus makan 3 kali untuk bisa berkonsentrasi menghafal Al-Qur\'an. Dengan biaya Rp 85 juta per bulan untuk pangan, kami seringkali harus menambah utang di warung ketika donasi belum mencukupi.',
    photo: '/images/drive-new/makan/bagi-makan-2.webp',
    alt: 'Santri sedang makan',
  },
  {
    icon: '\uD83D\uDCA1',
    title: 'Listrik Sering Padam Saat Belajar Malam',
    body: 'Waktu terbaik menghafal adalah malam hari. Tapi tagihan listrik pondok mencapai Rp 12 juta per bulan. Seringkali lampu belajar harus dimatikan lebih awal karena keterbatasan dana.',
    photo: '/images/drive-new/sarpras/7.webp',
    alt: 'Bangunan pondok pesantren',
  },
  {
    icon: '\uD83C\uDFEB',
    title: 'Fasilitas Belajar Masih Jauh dari Layak',
    body: 'Meja belajar yang rusak, kamar asrama yang penuh, dan ventilasi yang kurang — ini adalah kenyataan sehari-hari yang masih kami hadapi. Tapi semangat santri tidak pernah padam.',
    photo: '/images/drive-new/sarpras/1.webp',
    alt: 'Kondisi fasilitas pondok',
  },
  {
    icon: '\uD83D\uDCD6',
    title: 'Al-Qur\'an Layak Dibaca, Tapi Tidak Layak Pakai',
    body: 'Banyak mushaf Al-Qur\'an di pondok yang halaman-nya robek, cover-nya lepas, dan jilid-nya terlepas karena terlalu sering digunakan. Santri bergantian menggunakan satu buku untuk dua orang.',
    photo: '/images/drive-new/wisuda/wisuda-3.webp',
    alt: 'Santri wisuda Al-Qur\'an',
  },
];
---

<section id="kondisi" class="bg-primary-900 text-white py-20">
  <div class="max-w-5xl mx-auto px-4">
    <!-- Heading -->
    <div class="text-center mb-4">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Kondisi Santri Kita
      </h2>
    </div>

    <!-- Lead paragraph -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <p class="text-white/80 text-lg leading-relaxed">
        Di balik semangat mereka menghafal Al-Qur'an, ada perjuangan yang tidak terlihat.
        Ini adalah kondisi nyata yang terjadi setiap hari di pondok kami.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        kondisi.map((item, i) => (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 md:p-5 border border-white/10 grid grid-cols-1 md:grid-cols-2 gap-4 items-center">
            <img
              src={item.photo}
              alt={item.alt}
              class="w-full h-48 md:h-full object-cover rounded-lg"
              loading="lazy"
            />
            <div class={i % 2 !== 0 ? 'md:order-first' : ''}>
              <div class="text-3xl mb-3">{item.icon}</div>
              <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
              <p class="text-white/70 text-sm leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
