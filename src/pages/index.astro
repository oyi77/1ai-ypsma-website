---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Hero from '../components/sections/Hero.astro';
import KondisiSection from '../components/sections/KondisiSection.astro';
import StatsSection from '../components/sections/StatsSection.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import ProgramSection from '../components/sections/ProgramSection.astro';
import DonasiSection from '../components/sections/DonasiSection.astro';
import TestimonialSection from '../components/sections/TestimonialSection.astro';
import AyoBantuSection from '../components/sections/AyoBantuSection.astro';
import FAQSection from '../components/sections/FAQSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import Footer from '../components/sections/Footer.astro';
import StickyDonateButton from '../components/islands/StickyDonateButton';
---

<MainLayout>
  <Navbar />
  <main>
    <Hero />

    <!-- Social Proof Strip -->
    <div class="bg-white border-b border-neutral-100">
      <div class="max-w-6xl mx-auto px-4 py-4">
        <div class="flex items-center justify-center gap-6 md:gap-10 text-sm">
          <span class="text-neutral-500">
            <strong class="text-primary-700">1.247+</strong> Donatur
          </span>
          <span class="w-px h-4 bg-neutral-200 hidden sm:block"></span>
          <span class="text-neutral-500">
            <strong class="text-primary-700">600+</strong> Santri Terbantu
          </span>
          <span class="w-px h-4 bg-neutral-200 hidden sm:block"></span>
          <span class="text-neutral-500">
            <strong class="text-primary-700">98%</strong> Dana Tersalurkan
          </span>
        </div>
      </div>
    </div>
    <KondisiSection />
    <StatsSection />
    <TrustBar />
    <TestimonialSection />
    <ProgramSection />
    <AyoBantuSection />
    <FAQSection />
    <DonasiSection />
    <CTASection />
  </main>
  <Footer />

  <!-- Interactive Islands -->
  <StickyDonateButton client:load />
</MainLayout>
