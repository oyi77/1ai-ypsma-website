---
import MainLayout from '../../layouts/MainLayout.astro';
import { CAMPAIGNS } from '../../data/campaigns';
import CampaignDonateButton from '../../components/islands/CampaignDonateButton';
import StickyDonateButton from '../../components/islands/StickyDonateButton';

export async function getStaticPaths() {
  return CAMPAIGNS.map((c) => ({
    params: { slug: c.slug },
    props: { campaign: c },
  }));
}

const { campaign } = Astro.props;
const { title, subtitle, description, ogTitle, ogDescription, heroImage, badge, stats, stories, budgetLabel, budgetItems, budgetTotal, galleryImages, tiers, faqs } = campaign;
---

<MainLayout title={ogTitle} description={ogDescription}>
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt={title} class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900/95 via-primary-800/90 to-primary-700/85 z-10" />
    <div class="relative z-20 container mx-auto px-4 py-20 text-white">
      <span class="inline-block px-4 py-2 bg-white/15 backdrop-blur rounded-full text-sm font-medium mb-6">{badge}</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-4 max-w-3xl">{title}</h1>
      <p class="text-xl md:text-2xl text-white/80 max-w-2xl mb-8">{subtitle}</p>
      <div class="flex flex-wrap gap-8 mb-10">
        {stats.map(s => (
          <div>
            <div class="text-2xl md:text-3xl font-bold text-secondary-400">{s.value}</div>
            <div class="text-sm text-white/70">{s.label}</div>
          </div>
        ))}
      </div>
      <CampaignDonateButton campaign={campaign.slug} campaignLabel={title} variant="primary" size="lg" client:load />
    </div>
  </section>

  <!-- Stories -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4 text-center">Mengapa Program Ini?</h2>
      <p class="text-lg text-neutral-600 text-center mb-12 max-w-2xl mx-auto">{description}</p>
      <div class="grid md:grid-cols-3 gap-8">
        {stories.map(s => (
          <div class="bg-neutral-50 rounded-xl p-6 text-center hover:shadow-soft transition-shadow">
            <div class="text-4xl mb-4">{s.icon}</div>
            <h3 class="text-xl font-heading font-semibold text-primary-900 mb-3">{s.title}</h3>
            <p class="text-neutral-600 leading-relaxed">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Budget -->
  <section class="py-16 md:py-20 bg-neutral-50">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4 text-center">Transparansi Anggaran</h2>
      <p class="text-lg text-neutral-600 text-center mb-8">{budgetLabel}</p>
      <div class="bg-white rounded-xl shadow-soft overflow-hidden">
        <table class="w-full">
          <tbody>
            {budgetItems.map(b => (
              <tr class="border-b border-neutral-100 last:border-0">
                <td class="px-6 py-4 text-neutral-800">{b.label}</td>
                <td class="px-6 py-4 text-right font-semibold text-primary-900">{b.amount}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="bg-primary-900 text-white">
              <td class="px-6 py-4 font-heading font-semibold">Total</td>
              <td class="px-6 py-4 text-right font-heading font-bold text-lg">{budgetTotal}</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4 text-center">Galeri</h2>
      <p class="text-lg text-neutral-600 text-center mb-8">Lihat langsung aktivitas program</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {galleryImages.map(img => (
          <div class="aspect-[4/3] rounded-xl overflow-hidden">
            <img src={img} alt="" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tiers -->
  <section class="py-16 md:py-20 bg-neutral-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4 text-center">Pilih Nominal Donasi</h2>
      <p class="text-lg text-neutral-600 text-center mb-10">Setiap donasi Anda sangat berarti bagi mereka</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {tiers.map(t => (
          <div class={`rounded-xl p-6 text-center transition-all duration-200 hover:scale-105 ${t.featured ? 'bg-secondary-500 text-white shadow-strong ring-2 ring-secondary-300' : 'bg-white hover:shadow-soft border border-neutral-200'}`}>
            <div class={`text-2xl font-heading font-bold mb-1 ${t.featured ? 'text-white' : 'text-primary-900'}`}>{t.label}</div>
            <div class={`text-sm ${t.featured ? 'text-white/80' : 'text-neutral-500'}`}>{t.impact}</div>
            {t.featured && <div class="mt-2 text-xs bg-white/20 inline-block px-3 py-1 rounded-full">Populer</div>}
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <CampaignDonateButton campaign={campaign.slug} campaignLabel={title} variant="primary" size="lg" client:load />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-10 text-center">Tanya Jawab</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group bg-neutral-50 rounded-xl overflow-hidden">
            <summary class="px-6 py-5 font-heading font-semibold text-primary-900 cursor-pointer list-none flex justify-between items-center hover:bg-neutral-100 transition-colors">
              {f.question}
              <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-neutral-600 leading-relaxed">
              {f.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-primary-900 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Mulai Donasi Sekarang</h2>
      <p class="text-lg text-white/80 max-w-xl mx-auto mb-8">Setiap rupiah yang Anda donasikan menjadi cahaya bagi mereka dalam menuntut ilmu dan menghafal Al-Qur'an.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <CampaignDonateButton campaign={campaign.slug} campaignLabel={title} variant="primary" size="lg" client:load />
      </div>
    </div>
  </section>

  <StickyDonateButton client:load />
</MainLayout>
