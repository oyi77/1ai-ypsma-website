---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import { CAMPAIGNS } from '../../data/campaigns';
import CampaignDonateButton from '../../components/islands/CampaignDonateButton';
import { getWaUrl } from '../../lib/tracking';
import PhotoSlideshow from '../../components/islands/PhotoSlideshow';
import StickyDonateButton from '../../components/islands/StickyDonateButton';
import WhatsappDonasi from '../../components/islands/WhatsappDonasi';

export async function getStaticPaths() {
  return CAMPAIGNS.map((c) => ({
    params: { slug: c.slug },
    props: { campaign: c },
  }));
}

const { campaign } = Astro.props;
const { title, subtitle, description, ogTitle, ogDescription, heroImage, badge, stats, stories, budgetLabel, budgetItems, budgetTotal, galleryImages, tiers, faqs, hook, masalah, solusi, tokoh, testimoni, campaignUpdate, videoUrl, videoThumbnail, donaturCount } = campaign;
const waUrl = getWaUrl(campaign.slug).url;
---

<MainLayout title={ogTitle} description={ogDescription} canonical={`https://ypsma.org/program/${campaign.slug}/`}>
  <Navbar />

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 1: HERO — HOOK + VIDEO GAMBAR   -->
  <!-- ════════════════════════════════════════ -->
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={videoThumbnail || heroImage} alt={title} width="1200" height="800" class="w-full h-full object-cover" />
    </div>
    {hook ? (
      <div class="absolute inset-0 bg-gradient-to-br from-primary-900/70 via-primary-800/55 to-primary-700/40 z-10" />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-primary-900/95 via-primary-800/90 to-primary-700/85 z-10" />
    )}
    <div class="absolute inset-0 z-10 bg-gradient-to-t from-black/40 via-transparent to-transparent" />
    <div class="relative z-20 container mx-auto px-4 py-24 text-white">
      <span class="inline-block px-4 py-2 bg-white/15 backdrop-blur rounded-full text-sm font-medium mb-6">{badge}</span>

      <!-- HOOK: powerful headline -->
      {hook ? (
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6 max-w-3xl">{hook}</h1>
      ) : (
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-2 max-w-3xl">{title}</h1>
      )}
      <p class="text-xl md:text-2xl text-white/80 max-w-2xl mb-6">{hook ? description : subtitle}</p>

      <!-- VIDEO placeholder / embed -->
      {videoUrl && (
        <div class="mb-8 max-w-2xl">
          <a href={videoUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-3 px-6 py-3 bg-white/15 backdrop-blur rounded-full hover:bg-white/25 transition-colors text-white">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            <span class="font-medium">Tonton Video</span>
          </a>
        </div>
      )}

      <!-- STATS -->
      <div class="flex flex-wrap gap-8 mb-10">
        {stats.map(s => (
          <div>
            <div class="text-2xl md:text-3xl font-bold text-secondary-400">{s.value}</div>
            <div class="text-sm text-white/70">{s.label}</div>
          </div>
        ))}
      </div>

      <div class="flex flex-wrap gap-4">
        <CampaignDonateButton campaign={campaign.slug} campaignLabel={title} variant="primary" size="lg" client:load />
      </div>

      <!-- TRUST BADGES -->
      <div class="flex flex-wrap items-center gap-6 mt-6 text-sm text-white/75">
        <span class="inline-flex items-center gap-1.5">✅ <span>100% Tersalurkan ke Santri</span></span>
        <span class="inline-flex items-center gap-1.5">📋 <span>Laporan Bulanan</span></span>
        <span class="inline-flex items-center gap-1.5">🔒 <span>Pembayaran Aman</span></span>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 3: SATU TOKOH — Kisah Nyata    -->
  <!-- ════════════════════════════════════════ -->
  {tokoh && (
    <section class="py-20 md:py-28 bg-neutral-50" data-track-section="kisah-tokoh">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-14">
          <span class="inline-block px-4 py-1.5 bg-secondary-100 text-secondary-700 rounded-full text-sm font-semibold mb-4">SATU KISAH NYATA</span>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Lebih dari Sekadar Angka</h2>
          <p class="text-lg text-neutral-600 max-w-2xl mx-auto">Di balik setiap program, ada satu kisah yang mewakili semuanya.</p>
        </div>
        <div class="bg-white rounded-2xl shadow-soft overflow-hidden">
          <div class="md:flex">
            {tokoh.photo && (
              <div class="md:w-1/3 shrink-0">
                <img src={tokoh.photo} alt={tokoh.name} width="600" height="800" class="w-full h-80 md:h-full object-cover" />
              </div>
            )}
            <div class="p-8 md:p-10 md:w-2/3 flex flex-col justify-center">
              <div class="inline-block px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-sm font-medium mb-4">— {tokoh.name}, {tokoh.age} th{ tokoh.asal ? ` — ${tokoh.asal}` : '' }{ tokoh.role ? ` — ${tokoh.role}` : '' }</div>
              <p class="text-neutral-700 leading-relaxed text-lg mb-6 italic">"{tokoh.story}"</p>
              <div class="border-l-4 border-secondary-400 pl-4">
                <p class="text-primary-900 font-semibold italic">"{tokoh.quote}"</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 3: MASALAH — Emotional Problem  -->
  <!-- ════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-white" data-track-section="masalah">
      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 bg-red-50 text-red-600 rounded-full text-sm font-semibold mb-4">KENYATAAN DI LAPANGAN</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Apa yang Terjadi?</h2>
      </div>
      <div class="grid md:grid-cols-1 gap-8 max-w-4xl mx-auto">
        {(masalah || stories).map(s => (
          <div class="flex gap-5 items-start bg-neutral-50 rounded-2xl p-6 md:p-8 hover:shadow-soft transition-shadow">
            <div class="text-3xl md:text-4xl shrink-0 mt-1">{s.icon}</div>
            <div>
              <h3 class="text-xl font-heading font-bold text-primary-900 mb-2">{s.title}</h3>
              <p class="text-neutral-600 leading-relaxed">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 4: DATA DAMPAK — Fakta & Emosi  -->
  <!-- ════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-white" data-track-section="data-dampak">
      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 bg-blue-50 text-blue-600 rounded-full text-sm font-semibold mb-4">DATA & DAMPAK</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Mengapa Ini Mendesak?</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 mb-12 max-w-2xl mx-auto">
        {stats.map(s => (
          <div class="text-center bg-primary-50 rounded-2xl p-8 hover:shadow-soft transition-shadow">
            <div class="text-3xl md:text-4xl font-heading font-bold text-secondary-600 mb-2">{s.value}</div>
            <div class="text-neutral-600 font-medium">{s.label}</div>
          </div>
        ))}
      </div>
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-lg md:text-xl text-neutral-700 leading-relaxed">{description}</p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 5: SOLUSI — Apa yang Kami Lakukan-->
  <!-- ════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-primary-900 text-white" data-track-section="solusi">
      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 bg-white/15 rounded-full text-sm font-semibold mb-4">SOLUSI KAMI</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Apa yang Bisa Kami Lakukan Bersama?</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto">Dengan donasi Anda, kami bisa mewujudkan perubahan nyata.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {(solusi || stories).map((s, i) => (
          <div class="bg-white/10 backdrop-blur rounded-2xl p-6 hover:bg-white/15 transition-colors">
            <div class="text-2xl mb-3">{s.icon}</div>
            <h3 class="text-lg font-heading font-bold mb-2">{s.title}</h3>
            <p class="text-white/70 text-sm leading-relaxed">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 6: TARGET ANGGARAN — Transparan -->
  <!-- ════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-neutral-50">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 bg-green-50 text-green-600 rounded-full text-sm font-semibold mb-4">ANGGARAN TRANSPARAN</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Target Donasi</h2>
        <p class="text-lg text-neutral-600">{budgetLabel}</p>
      </div>
      <div class="bg-white rounded-2xl shadow-soft overflow-hidden">
        <table class="w-full">
          <tbody>
            {budgetItems.map(b => (
              <tr class="border-b border-neutral-100 last:border-0 hover:bg-neutral-50 transition-colors">
                <td class="px-6 py-4 text-neutral-800">{b.label}</td>
                <td class="px-6 py-4 text-right font-semibold text-primary-900 whitespace-nowrap">{b.amount}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="bg-primary-900 text-white">
              <td class="px-6 py-4 font-heading font-semibold">Total Kebutuhan</td>
              <td class="px-6 py-4 text-right font-heading font-bold text-lg">{budgetTotal}</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 7: GALERI — Foto Nyata        -->
  <!-- ════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 bg-purple-50 text-purple-600 rounded-full text-sm font-semibold mb-4">DOKUMENTASI</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Lihat Kondisi Nyata</h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">Foto-foto ini diambil langsung di lokasi — bukan dari internet.</p>
      </div>
      {galleryImages.length > 0 && (
        <PhotoSlideshow images={galleryImages} alt="Dokumentasi kondisi" client:load />
      )}
    </div>
  </section>

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 8: UPDATE — Perkembangan       -->
  <!-- ════════════════════════════════════════ -->
  {campaignUpdate && (
    <section class="py-20 md:py-28 bg-primary-50" data-track-section="update">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="text-center mb-10">
          <span class="inline-block px-4 py-1.5 bg-secondary-100 text-secondary-700 rounded-full text-sm font-semibold mb-4">PERKEMBANGAN TERKINI</span>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Update Program</h2>
          <p class="text-lg text-neutral-600">{campaignUpdate.date}</p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <div class="flex items-center gap-4 mb-6">
            <span class={`inline-block px-4 py-1.5 rounded-full text-sm font-medium ${
              campaignUpdate.status === 'berjalan' ? 'bg-green-100 text-green-700' :
              campaignUpdate.status === 'selesai' ? 'bg-blue-100 text-blue-700' :
              'bg-yellow-100 text-yellow-700'
            }`}>
              {campaignUpdate.status === 'berjalan' ? '🔄 Sedang Berjalan' :
               campaignUpdate.status === 'selesai' ? '✅ Selesai' : '⏳ Menunggu'}
            </span>
            {campaignUpdate.progress > 0 && (
              <span class="text-sm font-semibold text-primary-900">{campaignUpdate.progress}% terkumpul</span>
            )}
            {campaignUpdate.urgent && (
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-red-100 text-red-700 rounded-full text-sm font-semibold">
                ⚠️ Mendesak — Stok Terbatas
              </span>
            )}
          </div>
          {campaignUpdate.progress > 0 && (
            <div class="w-full bg-neutral-200 rounded-full h-3 mb-6">
              <div class="bg-secondary-500 h-3 rounded-full transition-all duration-1000" style={`width:${campaignUpdate.progress}%`} />
            </div>
          )}
          <p class="text-neutral-700 leading-relaxed">{campaignUpdate.note}</p>
        </div>
      </div>
    </section>
  )}

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 9: TESTIMONI — Suara Mereka    -->
  <!-- ════════════════════════════════════════ -->
  {testimoni && testimoni.length > 0 && (
    <section class="py-20 md:py-28 bg-white" data-track-section="testimoni">
        <div class="text-center mb-14">
          <span class="inline-block px-4 py-1.5 bg-secondary-100 text-secondary-700 rounded-full text-sm font-semibold mb-4">SUARA HATI</span>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Apa Kata Mereka?</h2>
          <p class="text-lg text-neutral-600 max-w-2xl mx-auto">Mereka yang terlibat langsung merasakan dampaknya.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {testimoni.map(t => (
            <div class="bg-neutral-50 rounded-2xl p-6 md:p-8 hover:shadow-soft transition-shadow">
              <div class="flex items-center gap-4 mb-4">
                {t.photo ? (
                  <img src={t.photo} alt={t.name} width="60" height="60" class="w-14 h-14 rounded-full object-cover" />
                ) : (
                  <div class="w-14 h-14 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 text-xl font-bold">{t.name.charAt(0)}</div>
                )}
                <div>
                  <div class="font-heading font-semibold text-primary-900">{t.name}</div>
                  <div class="text-sm text-neutral-500">{t.role}</div>
                </div>
              </div>
              <p class="text-neutral-600 italic leading-relaxed">"{t.quote}"</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
  <!-- ════════════════════════════════════════ -->
  <!-- SOCIAL PROOF — Trust Signals            -->
  <!-- ════════════════════════════════════════ -->
  {donaturCount && donaturCount > 0 && (
    <section class="py-12 md:py-16 bg-white">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="bg-primary-50 rounded-2xl p-8 md:p-10 text-center">
          <div class="flex flex-wrap justify-center gap-8 md:gap-12 mb-6">
            <div>
              <div class="text-3xl md:text-4xl font-heading font-bold text-primary-900">{donaturCount}</div>
              <div class="text-sm text-neutral-600 mt-1">Donatur Bergabung</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-heading font-bold text-primary-900">100%</div>
              <div class="text-sm text-neutral-600 mt-1">Transparan & Tersalurkan</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-heading font-bold text-primary-900">Aman</div>
              <div class="text-sm text-neutral-600 mt-1">Pembayaran Terenkripsi</div>
            </div>
          </div>
          <p class="text-neutral-600 text-sm">Laporan dampak bulanan dikirim ke setiap donatur via WhatsApp.</p>
        </div>
      </div>
    </section>
  )}

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 10: PILIH NOMINAL — Donasi     -->
  <!-- ════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-neutral-50" id="donasi" data-track-section="pilih-nominal">
      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 bg-secondary-100 text-secondary-700 rounded-full text-sm font-semibold mb-4">PILIH NOMINAL</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Mulai Donasi</h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">Pilih nominal di bawah. Setiap rupiah berarti.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
        {tiers.map(t => (
          <div class={`rounded-2xl p-6 text-center transition-all duration-200 hover:-translate-y-1 hover:shadow-strong ${t.featured ? 'bg-secondary-500 text-white shadow-strong ring-2 ring-secondary-300' : 'bg-white hover:shadow-soft border border-neutral-200'}`} data-track="tier" data-amount={t.amount}>
            <div class={`text-2xl font-heading font-bold mb-1 ${t.featured ? 'text-white' : 'text-primary-900'}`}>{t.label}</div>
            <div class={`text-sm ${t.featured ? 'text-white/80' : 'text-neutral-500'}`}>{t.impact}</div>
            {t.featured && <div class="mt-2 text-xs bg-white/20 inline-block px-3 py-1 rounded-full">⭐ Paling Populer</div>}
          </div>
        ))}
  </section>

  <!-- ════════════════════════════════════════ -->
  <!-- WhatsApp Pengurus — Konsultasi          -->
  <!-- ════════════════════════════════════════ -->
  <WhatsappDonasi campaign={campaign.slug} variant="card" client:load />

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 11: FAQ — Tanya Jawab          -->
  <!-- ════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="text-center mb-14">
        <span class="inline-block px-4 py-1.5 bg-neutral-100 text-neutral-600 rounded-full text-sm font-semibold mb-4">TANYA JAWAB</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-4">Pertanyaan Umum</h2>
      </div>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group bg-neutral-50 rounded-xl overflow-hidden transition-shadow hover:shadow-soft">
            <summary class="px-6 py-5 font-heading font-semibold text-primary-900 cursor-pointer list-none flex justify-between items-center hover:bg-neutral-100 transition-colors">
              {f.question}
              <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-neutral-600 leading-relaxed">
              {f.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════ -->
  <!-- SECTION 12: CTA FINAL — Aksi            -->
  <!-- ════════════════════════════════════════ -->
  <section class="py-20 md:py-28 bg-primary-900 text-white relative overflow-hidden" data-track-section="cta-final">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-secondary-500 rounded-full blur-3xl" />
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary-500 rounded-full blur-3xl" />
    </div>
    <div class="relative z-10 container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-5xl font-heading font-bold mb-6 max-w-4xl mx-auto">{campaign.cta || 'Ayo Berdonasi Sekarang'}</h2>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">Setiap Rp 50.000 bisa memberi makan seorang santri selama 3 hari. Bayangkan — kebaikan kecil Anda, bagi mereka sangat berarti.</p>
      <CampaignDonateButton campaign={campaign.slug} campaignLabel={title} variant="primary" size="lg" client:load />
      <a href={waUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-8 py-3 bg-white/15 hover:bg-white/25 backdrop-blur rounded-full text-white font-medium transition-colors">
