</MainLayout>

<script set:html={`
;(function(){
  var _cs = '${campaign.slug}';
  var _cn = '${title.replace(/'/g, "\\'")}';
  var _eSeq = 0;
  function _eid(ev) {
    return 'ypsma_' + ev + '_' + Date.now() + '_' + (++_eSeq);
  }

  if (window.fbq) {
    var _vcId = _eid('ViewContent');
    var _vcParams = {
      content_name: _cn, content_category: _cs,
      content_ids: [_cs], content_type: 'product',
      campaign_slug: _cs, campaign_name: _cn,
    };
    fbq('track', 'ViewContent', _vcParams, {eventID: _vcId});

    fetch('/api/meta-capi', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        event_name: 'ViewContent',
        event_id: _vcId,
        event_source_url: location.href,
        user_data: {},
        custom_data: _vcParams,
      }),
    }).catch(function(){});
  }

  document.addEventListener('click', function(e) {
    var tier = e.target.closest('[data-track="tier"]');
    if (tier && window.fbq) {
      fbq('track', 'AddToWishlist', {
        content_name: _cn, content_category: _cs,
        value: parseFloat(tier.getAttribute('data-amount')||'0'),
        currency: 'IDR', campaign_slug: _cs,
      });
    }
  });

  if ('IntersectionObserver' in window) {
    var _observed = new WeakSet();
    var _obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        if (_observed.has(el)) return;
        _observed.add(el);
        var sec = el.getAttribute('data-track-section');
        if (sec && window.fbq) {
          fbq('track', 'ViewContent', {
            content_name: _cn + ' \\u2014 ' + sec,
            content_category: _cs, campaign_slug: _cs,
          });
        }
      });
    }, { threshold: 0.4 });
    requestAnimationFrame(function() {
      document.querySelectorAll('[data-track-section]').forEach(function(el) { _obs.observe(el); });
    });
  }
})();
`} />


