---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import { ORG_SHORT } from '../lib/constants';
---

<MainLayout
  title={`Donasi Berhasil — ${ORG_SHORT}`}
  description="Terima kasih telah berdonasi. Donasi Anda sangat berarti bagi mereka yang membutuhkan."
>
  <Navbar />

  <section class="py-20 bg-gradient-to-b from-primary-900 to-primary-800 text-white">
    <div class="container mx-auto px-4 text-center">
      <div class="w-20 h-20 rounded-full mx-auto mb-6 flex items-center justify-center bg-green-500/20">
        <svg class="w-10 h-10 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">
        Donasi Berhasil!
      </h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Alhamdulillah, donasi Anda telah tercatat. Semoga menjadi amal jariyah
        yang tak terputus pahalanya.
      </p>
    </div>
  </section>

  <!-- Donation details (client-side rendered) -->
  <section class="py-12 bg-white" id="donation-details">
    <div class="container mx-auto px-4 max-w-lg">
      <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200 space-y-4">
        <h2 class="text-lg font-heading font-bold text-primary-900 text-center">
          Detail Donasi
        </h2>
        <div id="donation-detail-rows" class="space-y-3 text-sm">
          <!-- Populated by JS below -->
          <p class="text-center text-neutral-400 py-4">
            Memuat detail donasi...
          </p>
        </div>
      </div>

      <!-- WhatsApp confirmation -->
      <div class="mt-6 text-center" id="wa-section">
        <p class="text-neutral-600 text-sm mb-4">
          Konfirmasi donasi Anda melalui WhatsApp agar kami dapat memproses
          dan mengirimkan laporan penggunaan donasi.
        </p>
        <a
          href="https://wa.me/6285655713100"
          target="_blank"
          rel="noopener noreferrer"
          id="wa-button"
          class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white px-8 py-4 rounded-lg font-bold text-base transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Konfirmasi via WhatsApp
        </a>
      </div>

      <!-- Back to home -->
      <div class="mt-8 text-center">
        <a
          href="/"
          class="text-secondary-600 hover:text-secondary-700 font-semibold text-sm transition-colors"
        >
          &larr; Kembali ke Beranda
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const order = params.get('order') || '';
      const campaign = params.get('campaign') || '';
      const amount = params.get('amount') || '';

      // Build detail rows
      const rowsEl = document.getElementById('donation-detail-rows');
      if (rowsEl && (order || campaign || amount)) {
        let html = '';
        if (campaign) {
          html += '<div class="flex justify-between"><span class="text-neutral-500">Program</span>' +
            '<span class="font-medium text-neutral-800 text-right">' + escapeHtml(campaign) + '</span></div>';
        }
        if (amount) {
          const formatted = 'Rp' + parseInt(amount, 10).toLocaleString('id-ID');
          html += '<div class="flex justify-between"><span class="text-neutral-500">Nominal</span>' +
            '<span class="font-bold text-primary-900 text-lg">' + formatted + '</span></div>';
        }
        if (order) {
          html += '<div class="flex justify-between"><span class="text-neutral-500">Order ID</span>' +
            '<span class="font-mono text-xs text-neutral-600">' + escapeHtml(order) + '</span></div>';
        }
        rowsEl.innerHTML = html;
      } else if (rowsEl) {
        // No params — gracefully degrade
        rowsEl.innerHTML = '<p class="text-center text-neutral-500 py-4">' +
          'Detail donasi tidak tersedia. Silakan hubungi kami via WhatsApp untuk informasi lebih lanjut.</p>';
      }

      // Build WhatsApp URL
      const waBtn = document.getElementById('wa-button');
      if (waBtn && (order || campaign || amount)) {
        const text = 'Assalamualaikum, saya baru selesai donasi ' +
          (campaign || 'program YPSM') +
          (amount ? ' sebesar Rp' + parseInt(amount, 10).toLocaleString('id-ID') : '') +
          (order ? '. Order ID: ' + order : '') +
          '. Mohon konfirmasi penerimaan donasi. Jazakallahu khairan 🤲';
        waBtn.href = 'https://wa.me/6285655713100?text=' + encodeURIComponent(text);
      }

      function escapeHtml(str) {
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
      }
    })();
  </script>
</MainLayout>
