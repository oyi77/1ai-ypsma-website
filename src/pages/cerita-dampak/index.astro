---
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import { CAMPAIGNS } from '../../data/campaigns';
import { ORG_NAME } from '../../lib/constants';
---

<MainLayout
  title="Cerita Dampak Donasi YPSMA"
  description="Kisah nyata dampak donasi Anda untuk santri dan siswa YPSMA Jombang."
>
  <Navbar />
  <!-- Hero -->
  <section class="py-16 md:py-20 bg-gradient-to-b from-primary-900 to-primary-800 text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">Cerita Dampak</h1>
      <p class="text-lg text-white/80 max-w-3xl mx-auto">
        Di balik setiap donasi, ada kisah nyata. Dari suapan nasi hingga cahaya lampu belajar —
        setiap kontribusi mengubah hidup mereka.
      </p>
    </div>
  </section>

  <!-- Stories grouped by campaign -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      {CAMPAIGNS.map((c, ci) => (
        <div class="mb-16 last:mb-0">
          <!-- Campaign header -->
          <div class="flex items-center gap-4 mb-8 pb-4 border-b border-neutral-200">
            <div>
              <h2 class="text-2xl font-heading font-bold text-primary-900">{c.title}</h2>
              <p class="text-neutral-500 text-sm">{c.subtitle}</p>
            </div>
            <a
              href={`/program/${c.slug}/`}
              class="ml-auto text-sm text-secondary-600 hover:text-secondary-700 font-semibold shrink-0"
            >
              Donasi &rarr;
            </a>
          </div>

          <!-- Story cards -->
          <div class="grid md:grid-cols-3 gap-6">
            {c.stories.map(story => (
              <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-100 hover:shadow-soft transition-shadow">
                <div class="text-3xl mb-4">{story.icon}</div>
                <h3 class="font-bold text-primary-900 mb-3 leading-snug">{story.title}</h3>
                <p class="text-neutral-600 text-sm leading-relaxed">{story.body}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary-900 text-white">
    <div class="container mx-auto px-4 text-center max-w-3xl">
      <h2 class="text-3xl font-heading font-bold mb-4">Anda Bisa Jadi Bagian dari Cerita Ini</h2>
      <p class="text-white/70 mb-8">
        Setiap donasi — sekecil apa pun — menuliskan kisah baru bagi santri-santri yang berjuang menghafal
        Al-Qur'an dan menuntut ilmu. Mulai hari ini.
      </p>
      <a
        href="/program/"
        class="inline-block bg-coral-500 hover:bg-coral-600 text-white px-10 py-4 rounded-lg font-bold text-lg transition-colors"
      >
        &#10084; Pilih Program Donasi
      </a>
    </div>
  </section>
  <Footer />
</MainLayout>
