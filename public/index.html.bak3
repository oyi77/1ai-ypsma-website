          <li>Akses kunjungan ke pondok pesantren</li>
        </ul>
        <a href="https://kitabisa.com/ypmsa" target="_blank" rel="noopener" class="btn btn-primary w-full">Adopsi Orangtua Asuh ↗</a>
      </div>

      <!-- Tier 3 -->
      <div class="tier-card">
        <div class="tier-badge">Penguat Koperasi</div>
        <div class="tier-amount tier-amount-gold">Wakaf<span> / satu kali</span></div>
        <div class="tier-impact">Mendukung Modal Awal Koperasi Yayasan</div>
        <ul class="tier-perks">
          <li>Pencatatan aset wakaf atas nama donatur</li>
